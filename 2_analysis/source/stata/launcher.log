> 00) "\% \\" _n

. file write `tf' "Top 1\% of contracts (N = " %9.0fc (`top1pct') ")" " & " %6.
> 2f (`share_top1'*100) "\% \\" _n

. file write `tf' "Top 10\% of contracts (N = " %9.0fc (`top10pct') ")" " & " %
> 6.2f (`share_top10'*100) "\% \\" _n

