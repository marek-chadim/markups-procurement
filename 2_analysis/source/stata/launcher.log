>     "\begin{tabular}{lccc}" _n
>     "\toprule" _n
>     "Statistic & Value & SE method & N \\" _n
>     "\midrule" _n
> ;

. #delimit cr
delimiter now cr
. file write `tf' "Premium (analytical SE)" " & " %7.4f (`b_ana') " & " %7.4f (
> `se_ana') " & " %9.0fc (`n_ana') " \\" _n

. file write `tf' "Premium (cluster bootstrap)" " & " %7.4f (`b_boot') " & " %7
> .4f (`se_boot') " & " %9.0fc (`n_ana') " \\" _n

. if !mi(`ci_lo_piv') {
.     file write `tf' "~~95\% CI (percentile)" " & " ///
>         " [" %6.4f (`ci_lo_pct') ", " %6.4f (`ci_hi_pct') "]" ///
>         " & -- & -- \\" _n
.     file write `tf' "~~95\% CI (pivotal, Conlon)" " & " ///
>         " [" %6.4f (`ci_lo_piv') ", " %6.4f (`ci_hi_piv') "]" ///
>         " & -- & -- \\" _n
. }

. if !mi(`hansen_j_41') {
.     if !mi(`hansen_p_41') {
.         file write `tf' "Hansen J (NACE 41 TL, eff. W)" " & " ///
>             %7.3f (`hansen_j_41') " & p = " %6.4f (`hansen_p_41') " & -- \\" 
> _n
.     }
.     else {
.         file write `tf' "Hansen J (NACE 41 TL)" " & " ///
>             %7.3f (`hansen_j_41') " & -- & -- \\" _n
.     }
. }

. if !mi(`hansen_j_42') & !mi(`hansen_p_42') {
.     file write `tf' "Hansen J (NACE 42 TL, eff. W)" " & " ///
>         %7.3f (`hansen_j_42') " & p = " %6.4f (`hansen_p_42') " & -- \\" _n
. }

. if !mi(`hansen_j_43') & !mi(`hansen_p_43') {
.     file write `tf' "Hansen J (NACE 43 TL, eff. W)" " & " ///
>         %7.3f (`hansen_j_43') " & p = " %6.4f (`hansen_p_43') " & -- \\" _n
. }

