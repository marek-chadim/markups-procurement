151.         gen se_cogs2 = `sec2_v'
152.         gen b_kcogs = `bkc_v'
153.         gen se_kcogs = `skc_v'
154.         gen markup_mean = `mu_mean'
155.         gen criterion = `crit_v'
156.         gen hansen_j_eff = `hansen_j_v'
157.         gen n_overid = `n_overid_v'
158.         gen hansen_j_p = .
159.         if `n_overid_v' > 0 {
160.             replace hansen_j_p = chi2tail(`n_overid_v', `hansen_j_v')
161.         }
162.         append using `results'
163.         save `results', replace
164.         restore
165. 
.         dis "    beta_k = " %7.4f `bk_v' " (" %6.4f `sek_v' "), " ///
>             "beta_c = " %7.4f `bc_v' " (" %6.4f `sec_v' "), " ///
>             "mu_bar = " %6.3f `mu_mean'
166.     }
167. }


