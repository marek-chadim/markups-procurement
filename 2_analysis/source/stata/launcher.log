 16.         local p90 = r(p90)
 17. 
.         file write tf " & `slab'"
 18.         file write tf " & " %5.2f (`mn') " & " %5.2f (`sd')
 19.         file write tf " & " %5.2f (`p10') " & " %5.2f (`p50') " & " %5.2f 
> (`p90')
