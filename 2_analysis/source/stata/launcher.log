. cap mkdir "$output/data"

. save "$output/data/bmy_decomposition_czech.dta", replace
file ../../output/stata/data/bmy_decomposition_czech.dta saved

. export delimited year MU_agg Dagg_sum reall_inc_s Net_sum Daggmu Daggms Cross
>  net_entry ///
