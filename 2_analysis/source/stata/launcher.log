delimiter now ;
. file write `tf'
>     "\begin{table}[htbp]\centering" _n
>     "\caption{AGS (2017) Scaled Sensitivity $\hat\Lambda$ --- NACE 41 TL}" _n
>     "\label{tab:ags_twostep_sensitivity}" _n
>     "\begin{threeparttable}" _n
>     "\begin{tabular}{lcccccc}" _n
>     "\toprule" _n
>     "Moment $\\\\ \downarrow$ Parameter $\\\\ \rightarrow$ & const & $k$ & co
> gs & $k^2$ & cogs$^2$ & $k\cdot$cogs \\" _n
>     "\midrule" _n
> ;

. #delimit cr
delimiter now cr
. 
. local mnames "const k Lcogs k2 Lcogs2 kLcogs Lk L2cogs"

. forvalues i = 1/8 {
  2.     local m : word `i' of `mnames'
  3.     local mname = subinstr("`m'", "_", "\_", .)
  4.     file write `tf' "\texttt{`mname'}"
  5.     forvalues j = 1/6 {
  6.         local v = AGS_lambda[`i',`j']
  7.         file write `tf' " & " %10.2f (`v')
  8.     }
  9.     file write `tf' " \\" _n
 10. }

. 
. #delimit ;
delimiter now ;
. file write `tf'
>     "\bottomrule" _n
>     "\end{tabular}" _n
>     "\begin{tablenotes}\footnotesize" _n
>     "\item \emph{Notes:} $\hat\Lambda = -(\hat G'\hat W \hat G)^{-1}\hat G' "
>     "\hat W \cdot \text{diag}(\hat\sigma)$ evaluated at the translog ACF " _n
>     "GMM estimates for NACE 41. Rows are moments (instruments $\times$ " _n
>     "residual); columns are translog parameters. Large $|\Lambda|$ entries "
>     "identify load-bearing moments per Andrews, Gentzkow \& Shapiro (2017)." 
> _n
>     "\end{tablenotes}" _n
>     "\end{threeparttable}" _n
>     "\end{table}" _n
> ;

. #delimit cr
delimiter now cr
. file close `tf'

. dis "  Saved: ags_twostep_sensitivity.tex"
  Saved: ags_twostep_sensitivity.tex

. 
end of do-file

