. #delimit ;
delimiter now ;
. file write `tf'
>     "\begin{table}[htbp]\centering" _n
>     "\caption{Specification Curve: Procurement Markup Premium Across Variants
> }" _n
>     "\label{tab:spec_curve}" _n
>     "\begin{threeparttable}" _n
>     "\begin{tabular}{lcc}" _n
>     "\toprule" _n
>     "Specification & $\hat\beta$ & SE \\" _n
>     "\midrule" _n
> ;

