(2,796 missing values generated)

. gen pp_ever_3y = (pp_dummy == 1 | pp_L1 == 1 | pp_L2 == 1)

. replace pp_ever_3y = . if mi(pp_dummy)
(0 real changes made)

. label var pp_ever_3y "PP active in t, t-1, or t-2"

. drop pp_L1 pp_L2

