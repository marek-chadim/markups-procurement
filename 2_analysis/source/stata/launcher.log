. dis _newline "--- table_premium.do ---"

--- table_premium.do ---

. 
. use "$data/markups_panel.dta", clear

. 
. cap file close tf

. file open tf using "$output/table_premium.tex", write replace

. 
. #delimit ;
delimiter now ;
. file write tf
>     "\begin{table}[htbp]\centering" _n
>     "\caption{Procurement Markup Premium Across Specifications}" _n
>     "\label{tab:premium}" _n
>     "\begin{tabular}{l*{2}{c}}" _n
>     "\hline\hline" _n
>     " & pp\_t & pp\_ever\_3y \\" _n
>     "\hline" _n
>     "\multicolumn{3}{l}{\textit{Raw log markup difference}} \\" _n
> ;

. #delimit cr
delimiter now cr
. 
. foreach spec in A B C D E OLS {
  2.     if "`spec'"=="A" local lab "Base (surv.\ + pp)"
  3.     if "`spec'"=="B" local lab "No survival"
  4.     if "`spec'"=="C" local lab "No pp in Markov"
  5.     if "`spec'"=="D" local lab "Plain ACF"
  6.     if "`spec'"=="E" local lab "Translog"
  7.     if "`spec'"=="OLS" local lab "OLS"
  8. 
.     * pp_dummy raw
.     qui ttest l_mu_`spec', by(pp_dummy)
  9.     local raw = r(mu_2) - r(mu_1)
 10.     local se_raw = r(se)
 11.     * pp_ever_3y raw
.     qui ttest l_mu_`spec', by(pp_ever_3y)
 12.     local raw3 = r(mu_2) - r(mu_1)
 13.     local se3 = r(se)
 14. 
.     file write tf "`lab'"
 15.     file write tf " & " %6.3f (`raw') " & " %6.3f (`raw3') " \\" _n
 16.     file write tf " & (" %5.3f (`se_raw') ") & (" %5.3f (`se3') ") \\" _n
 17. }

. 
. #delimit ;
delimiter now ;
. file write tf
>     "\hline" _n
>     "\multicolumn{3}{l}{\textit{Regression (k, cogs, year x nace2 FE)}} \\" _
> n
> ;

. #delimit cr
delimiter now cr
. 
. foreach spec in A B C D E OLS {
  2.     if "`spec'"=="A" local lab "Base (surv.\ + pp)"
