>  \\" _n

. file write `tf' "8. NACE 43 only" " & " %7.4f (`b_43') " & " %7.4f (`s_43') "
>  \\" _n

. file write `tf' "9. pp\_ever\_3y treatment" " & " %7.4f (`b9') " & " %7.4f (`
> s9') " \\" _n

. file write `tf' "10. + k, cogs controls" " & " %7.4f (`b10') " & " %7.4f (`s1
> 0') " \\" _n

