>     "Notes: Markup " _char(36) "\mu = \hat{\theta}^V / \hat{\alpha}^V" _char(
> 36)
>     " where " _char(36) "\hat{\theta}^V" _char(36) " is the estimated output 
> elasticity"
>     " and " _char(36) "\hat{\alpha}^V" _char(36) " the corrected expenditure 
> share."
>     " Base = CD with survival + pp in Markov;"
>     " Plain = CD without Markov controls;"
>     " Translog = TL with survival + pp.} \\" _n
>     "\end{tabular}" _n
>     "\end{table}" _n
> ;

. #delimit cr
delimiter now cr
. 
. file close tf

. dis "  Saved: table_moments.tex"
  Saved: table_moments.tex

. 
end of do-file

. do "$code/table_correlations.do"

. *============================================================================
> ===
. * table_correlations.do — Table 4: Cross-Specification Correlations
. *
. * Analog of DGM Table 5:
. *   DGM: Pearson/Spearman correlations between quantity & revenue markups
. *   Us:  correlations between Base/Plain/TL/OLS markups (levels & FD)
. *
. * Output: output/table_correlations.tex
. *============================================================================
> ===
. 
. dis _newline "--- table_correlations.do ---"

--- table_correlations.do ---

. 
. 
. use "$data/markups_panel.dta", clear

. 
. * Balance panel on non-missing across specs
. drop if mi(l_mu_A) | mi(l_mu_D) | mi(l_mu_E) | mi(l_mu_OLS)
(0 observations deleted)

. 
. cap file close tf

. file open tf using "$output/table_correlations.tex", write replace

. 
. #delimit ;
delimiter now ;
. file write tf
>     "\begin{table}[htbp]\centering" _n
>     "\caption{Cross-Specification Markup Correlations}" _n
>     "\label{tab:correlations}" _n
>     "\begin{tabular}{l*{4}{c}}" _n
>     "\hline\hline" _n
>     " & Base--Plain & Base--TL & Base--OLS & Plain--OLS \\" _n
>     "\hline" _n
>     "\multicolumn{5}{l}{\textit{Levels (log markups)}} \\" _n
> ;

. #delimit cr
delimiter now cr
. 
. * Pearson correlations (levels)
. local pairs "A-D A-E A-OLS D-OLS"

. local labs  `""Base--Plain" "Base--TL" "Base--OLS" "Plain--OLS""'

. 
. * Pooled Pearson
. file write tf "Pearson (pooled)"

. foreach pair in A_D A_E A_OLS D_OLS {
  2.     local s1 = substr("`pair'", 1, strpos("`pair'","_")-1)
  3.     local s2 = substr("`pair'", strpos("`pair'","_")+1, .)
  4.     qui corr l_mu_`s1' l_mu_`s2'
  5.     file write tf " & " %5.3f (r(rho))
  6. }

. file write tf " \\" _n

. 
. * Spearman
. file write tf "Spearman (pooled)"

. foreach pair in A_D A_E A_OLS D_OLS {
  2.     local s1 = substr("`pair'", 1, strpos("`pair'","_")-1)
  3.     local s2 = substr("`pair'", strpos("`pair'","_")+1, .)
  4.     qui spearman l_mu_`s1' l_mu_`s2'
  5.     file write tf " & " %5.3f (r(rho))
  6. }

. file write tf " \\" _n

. 
. * By industry
. levelsof nace2, local(naces)
41 42 43

. foreach n of local naces {
  2.     file write tf "Pearson (NACE `n')"
  3.     foreach pair in A_D A_E A_OLS D_OLS {
  4.         local s1 = substr("`pair'", 1, strpos("`pair'","_")-1)
  5.         local s2 = substr("`pair'", strpos("`pair'","_")+1, .)
  6.         qui corr l_mu_`s1' l_mu_`s2' if nace2==`n'
  7.         file write tf " & " %5.3f (r(rho))
  8.     }
  9.     file write tf " \\" _n
 10. }

. 
. * First differences
. #delimit ;
delimiter now ;
. file write tf
>     "\hline" _n
>     "\multicolumn{5}{l}{\textit{First differences (" _char(36) "\Delta" _char
> (36) " log markups)}} \\" _n
> ;

. #delimit cr
delimiter now cr
. 
. * Pooled FD Pearson
. file write tf "Pearson (pooled)"

. foreach pair in A_D A_E A_OLS D_OLS {
  2.     local s1 = substr("`pair'", 1, strpos("`pair'","_")-1)
  3.     local s2 = substr("`pair'", strpos("`pair'","_")+1, .)
  4.     qui corr FD_l_mu_`s1' FD_l_mu_`s2'
  5.     file write tf " & " %5.3f (r(rho))
  6. }

. file write tf " \\" _n

. 
. * FD Spearman
. file write tf "Spearman (pooled)"

. foreach pair in A_D A_E A_OLS D_OLS {
  2.     local s1 = substr("`pair'", 1, strpos("`pair'","_")-1)
  3.     local s2 = substr("`pair'", strpos("`pair'","_")+1, .)
  4.     qui spearman FD_l_mu_`s1' FD_l_mu_`s2'
  5.     file write tf " & " %5.3f (r(rho))
  6. }

. file write tf " \\" _n

. 
. local N = _N

. #delimit ;
delimiter now ;
. file write tf
>     "\hline" _n
>     _char(36) "N" _char(36) " & \multicolumn{4}{c}{" %6.0fc (`N') "} \\" _n
>     "\hline\hline" _n
>     "\multicolumn{5}{p{11cm}}{\footnotesize" _n
>     "Notes: Correlations between log markups across specifications."
>     " Base = CD with survival + pp in Markov;"
>     " Plain = CD without Markov controls;"
>     " TL = translog; OLS = first-stage only."
>     " First differences: " _char(36) "\Delta\ln\mu_{it} = \ln\mu_{it} - \ln\m
> u_{it-1}" _char(36) ".} \\" _n
>     "\end{tabular}" _n
>     "\end{table}" _n
> ;

. #delimit cr
delimiter now cr
. 
. file close tf

. dis "  Saved: table_correlations.tex"
  Saved: table_correlations.tex

. 
end of do-file

. do "$code/table_dlw_eval.do"

. *============================================================================
> ===
. * table_dlw_eval.do — DLW (2012) Treatment Evaluation Framework
. *
. * Replicates De Loecker & Warzynski (2012, AER) treatment evaluation
. * with procurement status replacing export status:
. *   1. Cross-sectional premium (DLW Table 3, eq. 20)
. *   2. Entry/exit dynamics (DLW Table 4, eq. 22)
. *   3. Controlling for productivity (DLW eq. 21)
. *   4. Intensive margin (procurement share)
. *   5. Productivity-markup correlation (DLW Section V.C)
. *   6. Sub-industry heterogeneity (DLW destination analog)
. *   7. Event study (dynamic entry effects)
. *
. * Parallels Python dlw_treatment_eval.py
. *
. * Input:  $data/markups_panel.dta (from calculate_markups.do)
. * Output: $output/dlw_treatment_eval_stata.tex
. *         $output/dlw_event_study_stata.csv
. *============================================================================
> ===
. 
. dis _newline "--- table_dlw_eval.do ---"

--- table_dlw_eval.do ---

. 
. *-----------------------------------------------------------------------
. * Setup: check for reghdfe/estout, fall back gracefully
. *-----------------------------------------------------------------------
. 
. cap which reghdfe

. local has_reghdfe = (_rc == 0)

. if !`has_reghdfe' {
.     dis as text "  Note: reghdfe not installed; using areg with group FE"
. }

. 
. cap which esttab

. local has_estout = (_rc == 0)

. if !`has_estout' {
.     dis as text "  Note: estout not installed; using manual LaTeX output"
. }

. 
. *-----------------------------------------------------------------------
. * Load data
. *-----------------------------------------------------------------------
. 
. use "$data/markups_panel.dta", clear

. 
. * Verify key variables exist
. foreach v in l_mu_A omega_A pp_dummy k cogs nace2 year id {
  2.     cap confirm var `v'
  3.     if _rc {
  4.         dis as error "ERROR: variable `v' not found in markups_panel.dta"
  5.         error 198
  6.     }
  7. }

. 
. * Generate year × nace2 FE group
. cap drop yr_nace

. egen yr_nace = group(year nace2)

. 
. * Log markup shorthand
. local lmu "l_mu_A"

. 
. dis "  Loaded: " _N " obs, " r(N) " firms"
  Loaded: 9164 obs, . firms

. distinct id

       |        Observations
       |      total   distinct
-------+----------------------
    id |       9164       1498

. local N_firms = r(ndistinct)

. dis "  Firms: `N_firms'"
  Firms: 1498

. 
. *-----------------------------------------------------------------------
. * Construct entry/exit/always variables
. *-----------------------------------------------------------------------
. 
. sort id year

. 
. * First procurement year per firm
. bys id (year): gen _first_pp = year if pp_dummy == 1 & ///
>     (pp_dummy[_n-1] == 0 | _n == 1)
(7,933 missing values generated)

. bys id: egen first_pp_year = min(_first_pp)
(2,609 missing values generated)

. drop _first_pp

. 
. * Last procurement year per firm
. bys id: egen last_pp_year = max(cond(pp_dummy == 1, year, .))
(2,609 missing values generated)

. 
. * Last observed year per firm
. bys id: egen last_year = max(year)

. 
. * Always-procurer: pp_dummy = 1 in every year
. bys id: egen _min_pp = min(pp_dummy)

. gen always_pp = (_min_pp == 1)

. drop _min_pp

. 
. * Entry: non-always firm, post first procurement year
. gen entry_pp = 0

. replace entry_pp = 1 if always_pp == 0 & first_pp_year != . & ///
>     year >= first_pp_year
(3,322 real changes made)

. 
. * Exit: non-always firm, post last procurement year (firm stopped procuring)
. gen exit_pp = 0

. replace exit_pp = 1 if always_pp == 0 & last_pp_year != . & ///
>     last_pp_year < last_year & year > last_pp_year
(403 real changes made)

. 
. * Count switches for multi-switcher filter (DLW fn 52)
. bys id (year): gen _switch = abs(pp_dummy - pp_dummy[_n-1]) if _n > 1
(1,498 missing values generated)

. bys id: egen n_switches = total(_switch)

. drop _switch

. 
. * Procurement share (if available; fill 0 otherwise)
. cap confirm var pp_share

. if _rc {
.     gen pp_share = pp_dummy
.     label var pp_share "Procurement share (proxy = pp_dummy)"
. }

. replace pp_share = 0 if mi(pp_share)
(0 real changes made)

. 
. * Interactions for analysis 4
. gen pp_x_share = pp_dummy * pp_share

. label var pp_x_share "pp_dummy × pp_share"

. 
. dis _newline "  Entry/exit construction:"

  Entry/exit construction:

. dis "    Always-procurers: " %6.0f _N " obs where always_pp==1"
    Always-procurers:   9164 obs where always_pp==1

. count if always_pp == 1
  1,561

. dis "    Entry obs:        " r(N)
    Entry obs:        1561

. count if entry_pp == 1
  3,322

. dis "    Exit obs:         " r(N)
    Exit obs:         3322

. 
. * Preserve full sample before dropping multi-switchers
. tempfile fulldata

. save `fulldata'
file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St77944.000001 saved
