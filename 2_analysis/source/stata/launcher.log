: // --- Generic optimizer (NM only, robust) ---
: void run_opt(pointer(function) scalar fn, real rowvector sv,
>     string scalar bn, string scalar cn)
> {
>     S = optimize_init()
>     for (i=1; i<=8; i++) optimize_init_argument(S, i, .)
>     optimize_init_params(S, sv)
>     optimize_init_evaluator(S, fn)
>     optimize_init_which(S, "min")
>     optimize_init_conv_warning(S, "off")
>     optimize_init_conv_nrtol(S, 1e-10)
>     optimize_init_conv_maxiter(S, 10000)
>     optimize_init_technique(S, "nm")
>     optimize_init_tracelevel(S, "none")
> 
>     // Coarse NM
>     optimize_init_nmsimplexdeltas(S, 0.1)
>     p = optimize(S)
> 
>     // Refine NM (3 rounds with tight deltas)
>     optimize_init_nmsimplexdeltas(S, 1e-5)
>     optimize_init_params(S, p)
>     p = optimize(S)
>     optimize_init_params(S, p)
>     p = optimize(S)
>     optimize_init_params(S, p)
>     p = optimize(S)
> 
>     cb = optimize_result_value(S)
>     printf("  Criterion = %12.6f\n", cb)
>     printf("  Params: ")
>     for (j=1; j<=cols(p); j++) printf("%9.4f ", p[j])
>     printf("\n")
>     st_matrix(bn, p)
>     st_numscalar(cn, cb)
>     printf("  Matrix %s saved.\n", bn)
> }

: 
: // --- Analytical SEs (ACH 2012, clustered) ---
: void compute_se(string scalar bn, string scalar mt,
>     string rowvector zv, string rowvector xv,
>     string rowvector xlv)
> {
>     PHI = st_data(.,("phi"))
>     PHIL = st_data(.,("Lphi"))
>     C = st_data(.,("const"))
>     Z = st_data(.,zv)
>     X = st_data(.,xv)
>     XL = st_data(.,xlv)
>     cl = st_data(.,("id"))
>     b = st_matrix(bn)
>     N = rows(X)
>     Kz = cols(Z)
> 
>     if (mt=="base") {
>         MV = (C, st_data(.,("Lpp")), st_data(.,("Lphat")))
>     }
>     else if (mt=="pp") {
>         MV = (C, st_data(.,("Lpp")))
>     }
>     else if (mt=="surv") {
>         MV = (C, st_data(.,("Lphat")))
>     }
>     else {
>         MV = C
>     }
> 
>     // Omega and XI
>     OM = PHI - X*b'
>     OL = PHIL - XL*b'
>     P = (MV, OL)
>     gb = invsym(P'P) * P'OM
>     XI = OM - P*gb
> 
>     // Jacobian (numerical)
>     h = 1e-7
>     K = cols(b)
>     G = J(Kz, K, 0)
>     for (j=1; j<=K; j++) {
>         bp = b
>         bm = b
>         bp[j] = bp[j] + h
>         bm[j] = bm[j] - h
>         OMp = PHI - X*bp'
>         OLp = PHIL - XL*bp'
>         Pp = (MV, OLp)
>         gbp = invsym(Pp'Pp) * Pp'OMp
>         XIp = OMp - Pp*gbp
>         OMm = PHI - X*bm'
>         OLm = PHIL - XL*bm'
>         Pm = (MV, OLm)
>         gbm = invsym(Pm'Pm) * Pm'OMm
>         XIm = OMm - Pm*gbm
>         G[.,j] = (Z'XIp/N - Z'XIm/N) / (2*h)
>     }
> 
>     // Clustered meat (ACH 2012)
>     W = invsym(Z'Z/N)
>     ZXI = Z :* XI
>     cids = uniqrows(cl)
>     Nc = rows(cids)
>     S = J(Kz, Kz, 0)
>     for (c=1; c<=Nc; c++) {
>         sel = selectindex(cl :== cids[c])
>         mc = colsum(ZXI[sel,.])
>         S = S + mc'*mc
>     }
>     S = S/N * (Nc/(Nc-1))
>     GWGi = invsym(G'*W*G)
>     V = GWGi * G'*W*S*W*G * GWGi / N
>     st_matrix("V_an", V)
>     st_matrix("se_an", sqrt(diagonal(V))')
> }

: 
: end
-------------------------------------------------------------------------------

. 
. *-----------------------------------------------------------------------
. * Industry loop
. *-----------------------------------------------------------------------
. 
. local row = 0

. 
. foreach n of local nace2_list {
  2. 
.     dis _newline(2) "=========================================="
  3.     dis "  NACE2 = `n'"
  4.     dis "=========================================="
  5. 
.     preserve
  6.     keep if nace2 == `n'
  7. 
.     * Polynomial terms
.     gen k2 = k^2
  8.     gen cogs2 = cogs^2
  9.     gen kcogs = k * cogs
 10. 
.     * First stage OLS (with pp_dummy interactions + year FE)
.     xi: reg go c.k*#pp_dummy c.cogs*#pp_dummy i.year
 11.     predict phi
 12.     predict epsilon, res
 13.     local r2_1st = e(r2)
 14. 
.     * Corrected expenditure share
.     gen y_c = go - epsilon
 15.     gen Y_c = exp(y_c)
 16.     gen alphahat = exp(cogs) / Y_c
 17. 
.     * Lags
.     xtset id year
 18.     gen Lphi  = L.phi
 19.     gen Lpp   = L.pp_dummy
 20.     gen Lphat = L.phat_survival
 21.     gen Lk    = L.k
 22.     gen Lcogs = L.cogs
 23.     gen Lk2   = Lk^2
 24.     gen Lcogs2 = Lcogs^2
 25.     gen LkLcogs = Lk * Lcogs
 26.     gen kLcogs = k * Lcogs
 27.     gen const  = 1
 28. 
.     drop if mi(k, cogs, Lk, Lcogs, phi, Lphi, Lpp)
 29.     qui sum Lphat
 30.     replace Lphat = r(mean) if mi(Lphat)
 31. 
.     local nobs = _N
 32.     dis "  N = `nobs'"
 33. 
.     * OLS starting values
.     qui reg go k cogs
 34.     local sv_c = _b[_cons]
 35.     local sv_k = _b[k]
 36.     local sv_m = _b[cogs]
 37. 
.     * --- Spec A: Base ---
.     sort id year
 38.     mata: run_opt(&GMM_CD_BASE(), (`sv_c',`sv_k',`sv_m'), "bA", "cA")
 39.     local b0A = bA[1,1]
 40.     replace phi = phi - `b0A'
 41.     replace Lphi = Lphi - `b0A'
 42.     matrix bAnc = bA[1,2..3]
 43.     mata: compute_se("bAnc","base",("k","Lcogs"),("k","cogs"),("Lk","Lcogs
> "))
 44.     replace phi = phi + `b0A'
 45.     replace Lphi = Lphi + `b0A'
 46.     matrix seA = se_an
 47. 
.     * --- Spec B: No survival ---
.     sort id year
 48.     mata: run_opt(&GMM_CD_PP(), (`sv_c',`sv_k',`sv_m'), "bB", "cB")
 49.     local b0B = bB[1,1]
 50.     replace phi = phi - `b0B'
 51.     replace Lphi = Lphi - `b0B'
 52.     matrix bBnc = bB[1,2..3]
 53.     mata: compute_se("bBnc","pp",("k","Lcogs"),("k","cogs"),("Lk","Lcogs")
> )
 54.     replace phi = phi + `b0B'
 55.     replace Lphi = Lphi + `b0B'
 56.     matrix seB = se_an
 57. 
.     * --- Spec C: No pp ---
.     sort id year
 58.     mata: run_opt(&GMM_CD_SURV(), (`sv_c',`sv_k',`sv_m'), "bC", "cC")
 59.     local b0C = bC[1,1]
 60.     replace phi = phi - `b0C'
 61.     replace Lphi = Lphi - `b0C'
 62.     matrix bCnc = bC[1,2..3]
 63.     mata: compute_se("bCnc","surv",("k","Lcogs"),("k","cogs"),("Lk","Lcogs
> "))
 64.     replace phi = phi + `b0C'
 65.     replace Lphi = Lphi + `b0C'
 66.     matrix seC = se_an
 67. 
.     * --- Spec D: Plain ---
.     sort id year
 68.     mata: run_opt(&GMM_CD_PLAIN(), (`sv_c',`sv_k',`sv_m'), "bD", "cD")
 69.     local b0D = bD[1,1]
 70.     replace phi = phi - `b0D'
 71.     replace Lphi = Lphi - `b0D'
 72.     matrix bDnc = bD[1,2..3]
 73.     mata: compute_se("bDnc","plain",("k","Lcogs"),("k","cogs"),("Lk","Lcog
> s"))
 74.     replace phi = phi + `b0D'
 75.     replace Lphi = Lphi + `b0D'
 76.     matrix seD = se_an
 77. 
.     * --- Spec E: Translog ---
.     qui reg go k cogs k2 cogs2 kcogs
 78.     matrix sv_tl = (_b[_cons], _b[k], _b[cogs], _b[k2], _b[cogs2], _b[kcog
> s])
 79.     sort id year
 80.     mata: run_opt(&GMM_TL_BASE(), st_matrix("sv_tl"), "bE", "cE")
 81.     local b0E = bE[1,1]
 82.     replace phi = phi - `b0E'
 83.     replace Lphi = Lphi - `b0E'
 84.     matrix bEnc = bE[1,2..6]
 85.     mata: compute_se("bEnc","base", ///
>         ("k","Lcogs","k2","Lcogs2","kLcogs"), ///
>         ("k","cogs","k2","cogs2","kcogs"), ///
>         ("Lk","Lcogs","Lk2","Lcogs2","LkLcogs"))
 86.     replace phi = phi + `b0E'
 87.     replace Lphi = Lphi + `b0E'
 88.     matrix seE = se_an
 89. 
.     * --- OLS ---
.     qui reg go k cogs
 90.     local ols_k = _b[k]
 91.     local ols_m = _b[cogs]
 92. 
.     * --- Save coefficients ---
.     clear
 93.     set obs 1
 94.     gen nace2 = `n'
 95.     gen N_obs = `nobs'
 96.     gen r2_first = `r2_1st'
 97. 
.     foreach s in A B C D {
 98.         gen b_k_`s' = b`s'[1,2]
 99.         gen b_cogs_`s' = b`s'[1,3]
100.         gen se_k_`s' = se`s'[1,1]
101.         gen se_cogs_`s' = se`s'[1,2]
102.         gen crit_`s' = c`s'
103.     }
104.     gen b_k_E = bE[1,2]
105.     gen b_cogs_E = bE[1,3]
106.     gen b_k2_E = bE[1,4]
107.     gen b_cogs2_E = bE[1,5]
108.     gen b_kcogs_E = bE[1,6]
109.     gen se_k_E = seE[1,1]
110.     gen se_cogs_E = seE[1,2]
111.     gen se_k2_E = seE[1,3]
112.     gen se_cogs2_E = seE[1,4]
113.     gen se_kcogs_E = seE[1,5]
114.     gen crit_E = cE
115.     gen b_k_OLS = `ols_k'
116.     gen b_cogs_OLS = `ols_m'
117. 
.     save "$temp/coeff_`n'.dta", replace
118. 
.     restore
119. }


