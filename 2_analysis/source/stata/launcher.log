. levelsof nace2, local(naces)
41 42 43

. foreach n of local naces {
  2.     if `n'==41 local nlab "NACE 41 (Buildings)"
  3.     if `n'==42 local nlab "NACE 42 (Civil Eng.)"
  4.     if `n'==43 local nlab "NACE 43 (Specialized)"
  5. 
.     file write tf "\multicolumn{7}{l}{\textit{`nlab'}} \\" _n
  6. 
.     foreach s in A D E OLS {
  7.         if "`s'"=="A" local slab "Base"
  8.         if "`s'"=="D" local slab "Plain"
  9.         if "`s'"=="E" local slab "Translog"
 10.         if "`s'"=="OLS" local slab "OLS"
