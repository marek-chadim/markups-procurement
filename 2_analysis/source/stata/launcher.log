. * ---- Phase 2 Supplementary ----
. cap noisily do "$code/table_misspec_diagnostics.do"

. *============================================================================
> ===
. * table_misspec_diagnostics.do — Hansen J + Bootstrap SE (§6 Misspecification
> )
. *
. * Port of misspecification_diagnostics.py. Computes Hansen J overidentificati
> on
. * test for the translog ACF GMM and non-recentered cluster bootstrap SE for
. * the procurement premium.
. *
. * Input:  $data/markups_panel.dta
. * Output: ../../output/tables/misspecification_diagnostics.tex
. *============================================================================
> ===
. 
. dis _newline "--- table_misspec_diagnostics.do ---"

--- table_misspec_diagnostics.do ---

. 
. use "$data/markups_panel.dta", clear

. cap confirm var mu_A

. if _rc != 0 {
.     dis "  SKIP: missing mu_A"
.     exit
. }

. 
. gen log_mu = log(mu_A)

. 
. * Analytical SE baseline
. reghdfe log_mu pp_dummy k cogs, absorb(id year) vce(cluster id)
(dropped 200 singleton observations)
(MWFE estimator converged in 8 iterations)

HDFE Linear regression                            Number of obs   =      8,964
Absorbing 2 HDFE groups                           F(   3,   1297) =    1541.04
Statistics robust to heteroskedasticity           Prob > F        =     0.0000
                                                  R-squared       =     0.9882
                                                  Adj R-squared   =     0.9862
                                                  Within R-sq.    =     0.7149
Number of clusters (id)      =      1,298         Root MSE        =     0.0327

                                 (Std. err. adjusted for 1,298 clusters in id)
------------------------------------------------------------------------------
             |               Robust
      log_mu | Coefficient  std. err.      t    P>|t|     [95% conf. interval]
-------------+----------------------------------------------------------------
    pp_dummy |   .1371189     .00221    62.05   0.000     .1327834    .1414544
           k |   .0411479   .0014198    28.98   0.000     .0383626    .0439332
        cogs |  -.0601777   .0028326   -21.24   0.000    -.0657347   -.0546207
       _cons |   1.160963   .0428231    27.11   0.000     1.076953    1.244973
------------------------------------------------------------------------------

Absorbed degrees of freedom:
-----------------------------------------------------+
 Absorbed FE | Categories  - Redundant  = Num. Coefs |
-------------+---------------------------------------|
          id |      1298        1298           0    *|
        year |        16           1          15     |
-----------------------------------------------------+
* = FE nested within cluster; treated as redundant for DoF computation

. local b_ana = _b[pp_dummy]

. local se_ana = _se[pp_dummy]

. local n_ana = e(N)

. 
. * Non-recentered cluster bootstrap (999 reps, up from 500 — Conlon
. * bootstrap.tex convention for percentile CIs). Save replicates so we
. * can compute the pivotal CI `[2*theta_hat - q97.5, 2*theta_hat - q2.5]`
. * that Conlon (lines 75-82) calls "the Better Way" because of its
. * bias correction and higher-order Edgeworth refinement. Percentile
. * CI is preserved for cross-check.
. preserve

. qui tab year, gen(_by_)

. qui tab nace2, gen(_bn_)

. tempfile bs_reps

. cap bootstrap beta = _b[pp_dummy], reps(999) cluster(id) seed(42) nodots ///
>     saving("`bs_reps'", replace): ///
>     reg log_mu pp_dummy k cogs _by_* _bn_*

. local ci_lo_pct = .

. local ci_hi_pct = .

. local ci_lo_piv = .

. local ci_hi_piv = .

. if _rc == 0 {
.     matrix boot_V = e(V)
.     local se_boot = sqrt(boot_V[1, 1])
. 
.     * Load saved replicates and compute 2.5/97.5 quantiles via _pctile.
.     preserve
.     use "`bs_reps'", clear
.     cap confirm var beta
.     if _rc == 0 {
.         qui _pctile beta, p(2.5 97.5)
.         local ci_lo_pct = r(r1)
.         local ci_hi_pct = r(r2)
.         local ci_lo_piv = 2 * `b_ana' - `ci_hi_pct'
.         local ci_hi_piv = 2 * `b_ana' - `ci_lo_pct'
.     }
.     restore
. }

. else {
.     local se_boot = `se_ana'
. }

. restore

. local b_boot = `b_ana'

. 
. * Hansen J from the overidentified ACF TL. Prefer the new efficient-
. * weighted J (hansen_j_eff from table_beer_c2.do::compute_se, matches
. * Python lib/acf_estimator.py::_hansen_j_test) with proper p-value via
. * chi2tail. Fall back to the legacy crit_E if the new columns are not
. * present (backward-compatible with pre-2026-04-15 pipelines).
. local hansen_j_41 = .

. local hansen_p_41 = .

. local hansen_j_42 = .

. local hansen_p_42 = .

. local hansen_j_43 = .

. local hansen_p_43 = .

. 
. cap confirm file "$data/beer_c2_estimates.dta"

. if _rc == 0 {
.     preserve
.     use "$data/beer_c2_estimates.dta", clear
.     cap confirm var hansen_j_eff
.     if _rc == 0 {
.         * table_beer_c2.do writes sample labels "NACE 41", "NACE 42",
.         * "NACE 43" plus "Pooled"; filter to per-NACE rows only.
.         foreach n in 41 42 43 {
  2.             qui summ hansen_j_eff if sample == "NACE `n'" & spec == "TL"
  3.             if r(N) > 0 local hansen_j_`n' = r(mean)
  4.             qui summ hansen_j_p if sample == "NACE `n'" & spec == "TL"
  5.             if r(N) > 0 local hansen_p_`n' = r(mean)
  6.         }
.     }
.     restore
. }

. 
. * Legacy fallback: if new columns aren't in beer_c2_estimates yet,
. * read the one-step crit_E from coefficients_byind.dta and compute
. * its chi2tail as an approximation.
. if mi(`hansen_j_41') {
.     cap confirm file "$data/coefficients_byind.dta"
.     if _rc == 0 {
.         preserve
.         use "$data/coefficients_byind.dta", clear
.         cap confirm var crit_E
.         if _rc == 0 {
.             qui summ crit_E if nace2 == 41
.             if r(N) > 0 {
.                 local hansen_j_41 = r(mean)
.                 * crit_E is the one-step GMM criterion (W = inv(Z'Z)),
.                 * NOT the textbook efficient Hansen J. chi2tail is an
.                 * approximation under strong assumptions.
.                 local hansen_p_41 = chi2tail(2, `hansen_j_41')
.             }
.         }
.         restore
.     }
. }

. 
. * Retain a single-value `hansen_j` / `hansen_p` for the legacy
. * "Hansen J (NACE 41 TL)" row in the LaTeX output (unchanged format).
. local hansen_j = `hansen_j_41'

. local hansen_p = `hansen_p_41'

. 
. * Write LaTeX
. cap mkdir "$output/tables"

. tempname tf

. file open `tf' using "../../output/tables/misspecification_diagnostics.tex", 
> write replace

. #delimit ;
delimiter now ;
. file write `tf'
>     "\begin{table}[htbp]\centering" _n
>     "\caption{Misspecification Diagnostics: Bootstrap vs Analytical SE + Hans
> en J}" _n
>     "\label{tab:misspec}" _n
