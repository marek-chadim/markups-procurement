           k |   .0482031   .0007814    61.69   0.000     .0466714    .0497348
        cogs |  -.0466796   .0011279   -41.39   0.000    -.0488905   -.0444687
       _cons |   .8703055   .0144651    60.17   0.000     .8419507    .8986603
------------------------------------------------------------------------------

Absorbed degrees of freedom:
-----------------------------------------------------+
 Absorbed FE | Categories  - Redundant  = Num. Coefs |
-------------+---------------------------------------|
        year |        16           0          16     |
       nace2 |         3           1           2     |
-----------------------------------------------------+

. matrix lalonde_results[`row', 1] = _b[placebo]

. matrix lalonde_results[`row', 2] = _se[placebo]

. matrix lalonde_results[`row', 3] = e(N)

. 
. * Write LaTeX
. cap mkdir "$output/tables"

. tempname tf

. file open `tf' using "../../output/tables/lalonde_comparison.tex", write repl
> ace

. #delimit ;
delimiter now ;
. file write `tf'
>     "\begin{table}[htbp]\centering" _n
>     "\caption{LaLonde CIA Battery (Selection-on-Observables Estimators)}" _n
>     "\label{tab:lalonde}" _n
>     "\begin{threeparttable}" _n
>     "\begin{tabular}{lccc}" _n
>     "\toprule" _n
>     "Estimator & $\hat{ATT}$ & SE & N \\" _n
>     "\midrule" _n
> ;

. #delimit cr
delimiter now cr
. 
. local labs "OLS RA IPW IPWRA AIPW PSM1-1 PSM1-5 Kernel NN-Mahalanobis Caliper
> 0.1 Placebo"

. local i = 0

. foreach lab of local labs {
  2.     local ++i
  3.     local b = lalonde_results[`i', 1]
  4.     local s = lalonde_results[`i', 2]
  5.     local n = lalonde_results[`i', 3]
  6.     if !mi(`b') {
  7.         file write `tf' "`lab'" " & " %7.4f (`b') " & " %7.4f (`s') " & " 
> %9.0fc (`n') " \\" _n
  8.     }
  9.     else {
 10.         file write `tf' "`lab' & -- & -- & -- \\" _n
 11.     }
 12. }

. 
. #delimit ;
delimiter now ;
. file write `tf'
>     "\bottomrule" _n
>     "\end{tabular}" _n
>     "\begin{tablenotes}\footnotesize" _n
>     "\item \emph{Notes:} Eleven selection-on-observables estimators for the "
>  _n
>     "procurement markup premium. All methods control for log-inputs $(k, c)$ 
> " _n
>     "and year $\\times$ NACE fixed effects where applicable. The placebo " _n
>     "uses a random 50/50 split and should yield a coefficient near 0." _n
>     "\end{tablenotes}" _n
>     "\end{threeparttable}" _n
>     "\end{table}" _n
> ;

. #delimit cr
delimiter now cr
. file close `tf'

. dis "  Saved: lalonde_comparison.tex"
  Saved: lalonde_comparison.tex

