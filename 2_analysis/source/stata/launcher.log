>     "\hline" _n
>     "\multicolumn{4}{l}{\textit{Panel B: Robustness --- "
>     _char(36) "\hat{\beta}_{\text{cogs}}" _char(36) " (SE)}} \\" _n
> ;

. #delimit cr
delimiter now cr
. 
. foreach spec in B C D OLS {
  2.     if "`spec'"=="B" local lab "No survival"
  3.     if "`spec'"=="C" local lab "No pp in Markov"
  4.     if "`spec'"=="D" local lab "Plain ACF"
  5.     if "`spec'"=="OLS" local lab "OLS"
  6. 
.     file write tf "`lab'"
  7.     forvalues i = 1/3 {
  8.         local b = b_cogs_`spec'[`i']
  9.         file write tf " & " %6.4f (`b')
 10.     }
