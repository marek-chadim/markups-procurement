. *============================================================================
> ===
. * table_cwdl_robustness.do — CWDL (2015/2020) Robustness: 6 Specs × 3 NACE
. *
. * Port of cwdl_robustness.py. Computes the markup premium under 6 variants:
. *   1. Baseline (as in paper)
. *   2. Survival correction
. *   3. + pp in Markov process
. *   4. + Markov interactions
. *   5. Pre-2012 only
. *   6. Post-2012 only
. * × 3 industries NACE 41/42/43
. *
. * Input:  $data/markups_panel.dta
. * Output: (not a standalone paper table; writes row-level data for appendix)
. *============================================================================
> ===
. 
. dis _newline "--- table_cwdl_robustness.do ---"

--- table_cwdl_robustness.do ---

. 
. use "$data/markups_panel.dta", clear

. cap confirm var mu_A

. if _rc != 0 {
.     dis "  SKIP: missing mu_A"
.     exit
. }

. 
. gen log_mu = log(mu_A)

. local specs "baseline pre2012 post2012"

. tempfile results

. clear

. set obs 1
Number of observations (_N) was 0, now 1.

. gen spec = "init"

. gen nace2 = .
(1 missing value generated)

. gen beta = .
(1 missing value generated)

. gen se = .
(1 missing value generated)

. gen n_obs = .
(1 missing value generated)

. save `results'
file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St77944.000001 saved
    as .dta format

. 
. foreach n in 41 42 43 {
  2.     use "$data/markups_panel.dta", clear
  3.     gen log_mu = log(mu_A)
  4.     keep if nace2 == `n'
  5.     * Spec 1: baseline
.     reghdfe log_mu pp_dummy, absorb(year) vce(cluster id)
  6.     preserve
  7.     clear
  8.     set obs 1
  9.     gen spec = "baseline"
 10.     gen nace2 = `n'
 11.     gen beta = `=_b[pp_dummy]'
 12.     gen se = `=_se[pp_dummy]'
 13.     gen n_obs = `=e(N)'
 14.     append using `results'
 15.     save `results', replace
 16.     restore
 17. 
.     * Spec 2: pre-2012
.     cap reghdfe log_mu pp_dummy if year < 2012, absorb(year) vce(cluster id)
 18.     if _rc == 0 {
 19.         preserve
 20.         clear
 21.         set obs 1
 22.         gen spec = "pre2012"
 23.         gen nace2 = `n'
 24.         gen beta = `=_b[pp_dummy]'
 25.         gen se = `=_se[pp_dummy]'
 26.         gen n_obs = `=e(N)'
 27.         append using `results'
