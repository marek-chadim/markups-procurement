. use "$data/markups_panel.dta", clear

. 
. bys id: egen ever_pp_real = max(pp_dummy)

. gen log_mu = log(mu_A)

. gen post2012 = (year >= 2012)

. gen tp_real = ever_pp_real * post2012

. 
. * Observed DiD coefficient (same spec as table_reforms_mechanism.do)
. cap confirm var nace2

. if _rc != 0 {
.     dis "  ERROR: nace2 not found — skipping"
.     exit
. }

. 
. qui reghdfe log_mu tp_real post2012 k cogs, absorb(id year) vce(cluster id)

. local b_real = _b[tp_real]

. local se_real = _se[tp_real]

. dis "  Observed DiD: " %7.4f `b_real' " (SE " %7.4f `se_real' ")"
  Observed DiD:  0.0288 (SE  0.0041)

. 
. * ── Permute ever_pp within NACE 2-digit strata ──
. * Collapse to one row per firm, permute within NACE via self-merge on
. * (nace2, rank_key). The natural rank (pos_orig) is deterministic by id;
. * the shuffled rank (pos_shuf) comes from sorting on a random uniform key.
. * Lookup table: (nace2, pos_shuf → ever_pp_real); joined back on
. * (nace2, pos_orig = pos_shuf) gives each firm a shuffled value.
. preserve

. keep id nace2 ever_pp_real

. bys id: keep if _n == 1
(7,666 observations deleted)

. count
  1,498

. local n_firms = r(N)

. dis "  Firm-level obs: " `n_firms'
  Firm-level obs: 1498

. tempfile firm_level

. save `firm_level'
file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St77944.000002 saved
    as .dta format

. restore

. 
. set seed 42

. local K = 500

. local count_ge = 0

. matrix ri_betas = J(`K', 1, .)

. 
. * Pre-build once: the firm's deterministic pos_orig (doesn't change across it
> er)
. preserve

. use `firm_level', clear

. bys nace2 (id): gen pos_orig = _n

. tempfile firm_base

. save `firm_base'
file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St77944.000004 saved
    as .dta format

. restore

. 
. forvalues k = 1/`K' {
  2.     preserve
  3.     use `firm_base', clear
  4.     * Random position per firm within nace2
.     gen u = runiform()
  5.     sort nace2 u
  6.     by nace2: gen pos_shuf = _n
  7.     * Build lookup table in a separate tempfile (no nested preserve)
.     tempfile lookup
  8.     * First write the (nace2, pos_shuf, ever_pp_real) triples
.     qui save `lookup', replace
  9.     * Rename on disk via a sub-use
.     use `lookup', clear
 10.     keep nace2 pos_shuf ever_pp_real
 11.     rename pos_shuf pos_key
 12.     rename ever_pp_real ever_pp_perm
 13.     qui save `lookup', replace
 14.     * Now reload firm_base and merge: pos_orig as the join key
.     use `firm_base', clear
 15.     rename pos_orig pos_key
 16.     qui merge 1:1 nace2 pos_key using `lookup', nogen keep(master matched)
 17.     keep id ever_pp_perm
 18.     tempfile firm_perm
 19.     qui save `firm_perm'
 20.     restore
 21. 
.     preserve
 22.     qui merge m:1 id using `firm_perm', nogen keepusing(ever_pp_perm)
 23.     gen tp_perm = ever_pp_perm * post2012
 24.     qui reghdfe log_mu tp_perm post2012 k cogs, absorb(id year) vce(cluste
> r id)
 25.     matrix ri_betas[`k', 1] = _b[tp_perm]
 26.     if abs(_b[tp_perm]) >= abs(`b_real') local ++count_ge
 27.     restore
 28. 
.     if mod(`k', 50) == 0 dis "    iteration " `k' " / " `K'
 29. }
    iteration 50 / 500
    iteration 100 / 500
    iteration 150 / 500
    iteration 200 / 500
    iteration 250 / 500
    iteration 300 / 500
    iteration 350 / 500
    iteration 400 / 500
    iteration 450 / 500
    iteration 500 / 500

. 
. local ri_p = `count_ge' / `K'

. dis "  RI p-value (two-sided, |perm| >= |real|): " %6.4f `ri_p'
  RI p-value (two-sided, |perm| >= |real|): 0.0000

. dis "  (`count_ge' out of `K' permutations at least as extreme)"
