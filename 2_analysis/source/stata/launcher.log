> n

. file write `tf' "2. + year FE" " & " %7.4f (`b2') " & " %7.4f (`s2') " \\" _n

. file write `tf' "3. + year + NACE FE" " & " %7.4f (`b3') " & " %7.4f (`s3') "
>  \\" _n

. file write `tf' "4. + firm-clustered SE" " & " %7.4f (`b4') " & " %7.4f (`s4'
> ) " \\" _n

. file write `tf' "5. + firm FE" " & " %7.4f (`b5') " & " %7.4f (`s5') " \\" _n

. file write `tf' "6. NACE 41 only" " & " %7.4f (`b_41') " & " %7.4f (`s_41') "
