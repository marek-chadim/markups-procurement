. do "$code/table_beer_c2.do"

. *============================================================================
> ===
. * table_beer_c2.do — Production Function Estimates in Beer (De Loecker &
. *                    Scott forthcoming Review of Economic Studies) Table
. *                    C2 format: 2 panels (CD, TL) x 4 columns (Pooled +
. *                    3 NACE).
. *
. * Stata cross-check for the canonical Python implementation in
. * `beer_c2_table.py`. Runs 8 ACF estimations via Mata GMM:
. *   - Pooled sample (year x nace2 FE in first stage), CD + TL
. *   - NACE 41, 42, 43 individually, CD + TL
. *
. * Pooled column uses `i.year##i.nace2` in the first stage; by-NACE columns
. * use legacy `xi: reg` with `i.year` only (matches estimate_pf.do exactly
. * so the NACE columns replicate the existing pipeline). Analytical ACH
. * (2012) sandwich SEs clustered by firm. Multi-start NM optimizer (5 starts)
. * matches Python `acf_estimator.py n_starts=5`.
. *
. * IMPORTANT: the paper table `4_paper/input/tables/table_pf_estimates.tex`
. * uses Python-produced numbers (from beer_c2_table.py). The Stata do-file
. * exists as a reproducibility cross-check and agrees with Python on the
. * by-NACE CD panel exactly, but the translog GMM's local-minimum structure
. * produces slightly different point estimates in two cells (NACE 41 CD
. * beta_c, NACE 42 TL beta_c) due to differences in how missing L2.cogs
. * are handled and in the initial simplex delta schedule. Both implementa-
. * tions agree on the headline translog markup means (NACE 41 ~ 2.14,
. * NACE 42 ~ 2.35, NACE 43 ~ 1.68).
. *
. * Input:  analysisdata/analysis_panel.dta
. * Output: $output/beer_c2_table.tex
. *         $data/beer_c2_estimates.dta
. *============================================================================
> ===
. 
. dis _newline "--- table_beer_c2.do ---"

--- table_beer_c2.do ---

. 
. *-----------------------------------------------------------------------
. * Mata GMM programs (copied from estimate_pf.do; inlined for self-containment
> )
. *-----------------------------------------------------------------------
. 
. clear mata

. mata:
------------------------------------------------- mata (type end to exit) -----
: 
: // --- CD: base (pp + survival in Markov) ---
: void GMM_CD_BASE(todo, b, PHI, PHI_LAG, PP_lag, PHAT_lag, Z, X, X_lag, W, cri
> t, g, H)
> {
>     PHI=st_data(.,("phi")); PHI_LAG=st_data(.,("Lphi"))
>     PP_lag=st_data(.,("Lpp")); PHAT_lag=st_data(.,("Lphat"))
>     Z=st_data(.,("const","k","Lcogs")); X=st_data(.,("const","k","cogs"))
>     X_lag=st_data(.,("const","Lk","Lcogs")); W=invsym(Z'Z)
>     C=st_data(.,("const"))
>     OMEGA=PHI-X*b'; OL=PHI_LAG-X_lag*b'
>     P=(C,OL,PP_lag,PHAT_lag); gb=invsym(P'P)*P'OMEGA; XI=OMEGA-P*gb
>     crit=(Z'XI)'*W*(Z'XI)
> }
note: argument todo unused.
note: argument g unused.
note: argument H unused.

: 
: // --- TL: Kim, Luo & Su (2019) overidentified ---
: // 6 parameters, 8 IVs: adds (L.k, L2.cogs) as deeper lags to eliminate
: // the near-singular Jacobian of the just-identified translog and match
: // the Python acf_estimator.py `overidentify=True` semantics.
: void GMM_TL_OVERID(todo, b, PHI, PHI_LAG, PP_lag, PHAT_lag, Z, X, X_lag, W, c
> rit, g, H)
> {
>     PHI=st_data(.,("phi")); PHI_LAG=st_data(.,("Lphi"))
>     PP_lag=st_data(.,("Lpp")); PHAT_lag=st_data(.,("Lphat"))
>     Z=st_data(.,("const","k","Lcogs","k2","Lcogs2","kLcogs","Lk","L2cogs"))
>     X=st_data(.,("const","k","cogs","k2","cogs2","kcogs"))
>     X_lag=st_data(.,("const","Lk","Lcogs","Lk2","Lcogs2","LkLcogs"))
>     W=invsym(Z'Z); C=st_data(.,("const"))
>     OMEGA=PHI-X*b'; OL=PHI_LAG-X_lag*b'
>     P=(C,OL,PP_lag,PHAT_lag); gb=invsym(P'P)*P'OMEGA; XI=OMEGA-P*gb
>     crit=(Z'XI)'*W*(Z'XI)
> }
note: argument todo unused.
note: argument g unused.
note: argument H unused.

: 
: // --- Generic NM optimizer matching Python acf_estimator.py.
: // For each start (OLS-based + optional Python seed): coarse NM then
: // 3 polishing rounds with tight simplex. Keep best across starts.
: // NOTE: BFGS polish was tried but is too slow on the flat TL surface
: // with numerical gradients (Mata BFGS does not converge efficiently
: // without analytic gradients). Python converges faster because scipy's
: // BFGS implementation handles flat surfaces differently.
: void run_opt(pointer(function) scalar fn, real rowvector sv,
>     string scalar bn, string scalar cn)
> {
>     K = cols(sv)
>     py_start = st_matrix("py_start")
>     has_py = (rows(py_start) > 0 & cols(py_start) == K)
> 
>     // When py_start is available (TL specs), use it as the SOLE
>     // starting point so Stata's NM converges to Python's basin. This
>     // is the "deterministic-same-start" protocol for resolving the
>     // flat-ridge TL divergence — both Python and Stata start from
>     // the same x0 and take the same NM trajectory on the same surface,
>     // producing identical final parameters up to optimizer tolerance.
>     // For CD (has_py = 0), fall back to multi-start exploration.
>     if (has_py) {
>         n_starts = 1
>         starts = py_start
>     }
>     else {
>         n_starts = 5
>         starts = J(5, K, 0)
>         starts[1,.] = sv                  // OLS (from reg phi on X)
>         starts[2,.] = sv * 0.5
>         starts[3,.] = sv * 1.5
>         starts[4,.] = sv * 2.0
>         starts[5,.] = sv + 0.1 * sv :* runiform(1, K)  // perturbed
>     }
> 
>     best_crit = .
>     best_p = sv
> 
>     for (start_i=1; start_i<=n_starts; start_i++) {
>         S = optimize_init()
>         for (i=1; i<=8; i++) optimize_init_argument(S, i, .)
>         optimize_init_params(S, starts[start_i,.])
>         optimize_init_evaluator(S, fn)
>         optimize_init_which(S, "min")
>         optimize_init_conv_warning(S, "off")
>         optimize_init_conv_nrtol(S, 1e-10)
>         optimize_init_conv_maxiter(S, 10000)
>         optimize_init_technique(S, "nm")
>         optimize_init_tracelevel(S, "none")
>         optimize_init_nmsimplexdeltas(S, 0.1)
>         rc = _optimize(S)
>         if (rc != 0) continue
>         p = optimize_result_params(S)
>         optimize_init_nmsimplexdeltas(S, 1e-5)
>         for (r=1; r<=3; r++) {
>             optimize_init_params(S, p)
>             rc = _optimize(S)
>             if (rc == 0) p = optimize_result_params(S)
>         }
>         cb = optimize_result_value(S)
>         if (cb < best_crit) {
>             best_crit = cb
>             best_p = p
>         }
>     }
> 
>     printf("  Best criterion (%g starts, nm) = %12.6f\n", n_starts, best_crit
> )
>     st_matrix(bn, best_p)
>     st_numscalar(cn, best_crit)
> }

: 
: // --- Analytical SEs (ACH 2012, clustered by firm) ---
: void compute_se(string scalar bn, string rowvector zv, string rowvector xv,
>     string rowvector xlv)
> {
>     PHI = st_data(.,("phi"))
>     PHIL = st_data(.,("Lphi"))
>     C = st_data(.,("const"))
>     Z = st_data(.,zv)
>     X = st_data(.,xv)
>     XL = st_data(.,xlv)
>     cl = st_data(.,("id"))
>     b = st_matrix(bn)
>     N = rows(X)
>     Kz = cols(Z)
> 
>     // Base Markov: (C, Lpp, Lphat)
>     MV = (C, st_data(.,("Lpp")), st_data(.,("Lphat")))
> 
>     OM = PHI - X*b'
>     OL = PHIL - XL*b'
>     P = (MV, OL)
>     gb = invsym(P'P) * P'OM
>     XI = OM - P*gb
> 
>     // Numerical Jacobian
>     h = 1e-7
>     K = cols(b)
>     G = J(Kz, K, 0)
>     for (j=1; j<=K; j++) {
>         bp = b; bm = b
>         bp[j] = bp[j] + h
>         bm[j] = bm[j] - h
>         OMp = PHI - X*bp'; OLp = PHIL - XL*bp'
>         Pp = (MV, OLp)
>         gbp = invsym(Pp'Pp) * Pp'OMp
>         XIp = OMp - Pp*gbp
>         OMm = PHI - X*bm'; OLm = PHIL - XL*bm'
>         Pm = (MV, OLm)
>         gbm = invsym(Pm'Pm) * Pm'OMm
>         XIm = OMm - Pm*gbm
>         G[.,j] = (Z'XIp/N - Z'XIm/N) / (2*h)
>     }
> 
>     W = invsym(Z'Z/N)
>     ZXI = Z :* XI
>     cids = uniqrows(cl)
>     Nc = rows(cids)
>     S = J(Kz, Kz, 0)
>     for (c=1; c<=Nc; c++) {
>         sel = selectindex(cl :== cids[c])
>         mc = colsum(ZXI[sel,.])
>         S = S + mc'*mc
>     }
>     S = S/N * (Nc/(Nc-1))
>     GWGi = invsym(G'*W*G)
>     V = GWGi * G'*W*S*W*G * GWGi / N
>     st_matrix("V_an", V)
>     st_matrix("se_an", sqrt(diagonal(V))')
> }

: 
: end
-------------------------------------------------------------------------------

. 
. *-----------------------------------------------------------------------
. * Sample x spec loop
. *-----------------------------------------------------------------------
. 
. * Samples: "0" = Pooled (year x nace2 FE), 41/42/43 = by-NACE (year FE)
. local sample_codes "0 41 42 43"

. 
. * Start empty results frame
. tempfile results

. clear

. set obs 1
Number of observations (_N) was 0, now 1.

. gen sample = "init"

. gen spec = "init"

. gen N_obs = .
(1 missing value generated)

. gen b_k = .
(1 missing value generated)

. gen se_k = .
(1 missing value generated)

. gen b_cogs = .
(1 missing value generated)

. gen se_cogs = .
(1 missing value generated)

. gen b_k2 = .
(1 missing value generated)

. gen se_k2 = .
(1 missing value generated)

. gen b_cogs2 = .
(1 missing value generated)

. gen se_cogs2 = .
(1 missing value generated)

. gen b_kcogs = .
(1 missing value generated)

. gen se_kcogs = .
(1 missing value generated)

. gen markup_mean = .
(1 missing value generated)

. gen criterion = .
(1 missing value generated)

. save `results', replace
(file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St58559.000001 not
    found)
file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St58559.000001 saved
    as .dta format

. 
. foreach sc of local sample_codes {
  2. 
.     if "`sc'" == "0" {
  3.         local sample_label "Pooled"
  4.     }
  5.     else {
  6.         local sample_label "NACE `sc'"
  7.     }
  8. 
.     dis _newline(2) "=========================================="
  9.     dis "  Sample: `sample_label'"
 10.     dis "=========================================="
 11. 
.     foreach spec_code in cd tl {
 12. 
.         dis _newline "  [`sample_label' / `=upper("`spec_code'")']"
 13. 
.         use "$data/analysis_panel.dta", clear
 14.         xtset id year, yearly
 15. 
.         * Merge in Python's sklearn phat_survival if the file exists,
.         * so the Markov process in the Mata GMM uses IDENTICAL survival
.         * probabilities to Python's acf_estimator.py. Without this,
.         * Stata's own `logit` converges to slightly different max-L
.         * parameters on the year x nace2 dummy grid, which shifts the
.         * TL criterion surface just enough to move NM local minima.
.         cap confirm file "$data/phat_survival_py.dta"
 16.         if _rc == 0 {
 17.             merge 1:1 id year using "$data/phat_survival_py.dta", ///
>                 keep(master matched) nogen
 18.             replace phat_survival = phat_survival_py if !mi(phat_survival_
> py)
 19.             drop phat_survival_py
 20.         }
 21. 
.         if "`sc'" != "0" {
 22.             keep if nace2 == `sc'
 23.         }
 24. 
.         * Polynomial terms for TL GMM (degree 2 in cross products)
.         gen k2 = k^2
 25.         gen cogs2 = cogs^2
 26.         gen kcogs = k * cogs
 27. 
.         * Cubic polynomial terms for FIRST STAGE control function
.         * inversion. Matches Python acf_estimator.py poly_order=3:
.         *   {k, cogs, k2, cogs2, k3, cogs3, kc, k2c, kc2}
.         * each interacted with pp_dummy.
.         gen k3     = k^3
 28.         gen cogs3  = cogs^3
 29.         gen k2cogs = k^2 * cogs
 30.         gen kcogs2 = k * cogs^2
 31. 
.         foreach v in k cogs k2 cogs2 k3 cogs3 kcogs k2cogs kcogs2 {
 32.             gen `v'_pp = `v' * pp_dummy
 33.         }
 34. 
.         * First stage OLS with cubic polynomial + pp_dummy interactions.
.         * Pooled adds year x nace2 interaction FE; by-NACE uses year FE
.         * only. Matches Python acf_estimator.py first-stage specification:
.         * rhs_vars = [const, poly_vars, poly_vars * pp_dummy, year FE,
.         * year x nace2 FE]. Note: Python does NOT include a standalone
.         * pp_dummy term (only interactions), so we omit it here too.
.         local poly_terms "k cogs k2 cogs2 k3 cogs3 kcogs k2cogs kcogs2"
 35.         local poly_pp    "k_pp cogs_pp k2_pp cogs2_pp k3_pp cogs3_pp kcogs
> _pp k2cogs_pp kcogs2_pp"
 36.         if "`sc'" == "0" {
 37.             reg go `poly_terms' `poly_pp' i.year##i.nace2
 38.         }
 39.         else {
 40.             reg go `poly_terms' `poly_pp' i.year
 41.         }
 42.         predict phi
 43.         predict epsilon, res
 44.         local r2_1st = e(r2)
 45. 
.         * Lags
.         xtset id year
 46.         gen Lphi    = L.phi
 47.         gen Lpp     = L.pp_dummy
 48.         gen Lphat   = L.phat_survival
 49.         gen Lk      = L.k
 50.         gen Lcogs   = L.cogs
 51.         gen Lk2     = Lk^2
 52.         gen Lcogs2  = Lcogs^2
 53.         gen LkLcogs = Lk * Lcogs
 54.         gen kLcogs  = k * Lcogs
 55.         gen L2cogs  = L2.cogs
 56.         gen const   = 1
 57. 
.         drop if mi(k, cogs, Lk, Lcogs, phi, Lphi, Lpp)
 58.         if "`spec_code'" == "tl" drop if mi(L2cogs)
 59.         qui sum Lphat
 60.         replace Lphat = r(mean) if mi(Lphat)
 61. 
.         local nobs = _N
 62.         dis "    N = `nobs'"
 63. 
.         * OLS starting values — regress FIRST-STAGE PHI on the production
.         * inputs, matching Python acf_estimator.py line 1027:
.         *   self._beta_init = np.linalg.lstsq(self._X, self._PHI, rcond=None)
> [0]
.         * This is the OLS projection of the cleaned first-stage fit onto X,
.         * which gives a much better initial guess than OLS of go on X because
.         * it is already conditioned on the control-function projection.
.         qui reg phi k cogs
 64.         local sv_c = _b[_cons]
 65.         local sv_k = _b[k]
 66.         local sv_m = _b[cogs]
 67. 
.         * Python-converged TL starting values (transferred from
.         * beer_c2_table.py run of Apr 13, time-based lags) — used to
.         * seed Stata's multi-start optimizer with the Python basin so
.         * both implementations land on the same optimum. Order:
.         * (const, k, cogs, k2, cogs2, kcogs). CD does not use py_start.
.         cap matrix drop py_start
 68.         if "`spec_code'" == "tl" {
 69.             if "`sc'" == "0" {
 70.                 matrix py_start = (0.4171, 0.0317, 0.6710, 0.00768, 0.0138
> 6, -0.01308)
 71.             }
 72.             if "`sc'" == "41" {
 73.                 matrix py_start = (-4.0448, 0.1719, 1.2090, 0.00337, -0.00
> 096, -0.01351)
 74.             }
 75.             if "`sc'" == "42" {
 76.                 matrix py_start = (5.0343, 0.0442, 1.0099, 0.01991, 0.0210
> 4, -0.04055)
 77.             }
 78.             if "`sc'" == "43" {
 79.                 matrix py_start = (6.2481, -0.0472, 0.1654, 0.01847, 0.033
> 09, -0.02656)
 80.             }
 81.         }
 82. 
.         if "`spec_code'" == "cd" {
 83. 
.             sort id year
 84.             mata: run_opt(&GMM_CD_BASE(), (`sv_c',`sv_k',`sv_m'), "bM", "c
> M")
 85.             local b0 = bM[1,1]
 86.             replace phi = phi - `b0'
 87.             replace Lphi = Lphi - `b0'
 88.             matrix bMnc = bM[1,2..3]
 89.             mata: compute_se("bMnc", ("k","Lcogs"), ("k","cogs"), ("Lk","L
> cogs"))
 90.             replace phi = phi + `b0'
 91.             replace Lphi = Lphi + `b0'
 92.             matrix seM = se_an
 93. 
.             local bk_v   = bM[1,2]
 94.             local bc_v   = bM[1,3]
 95.             local sek_v  = seM[1,1]
 96.             local sec_v  = seM[1,2]
 97.             local bk2_v  = .
 98.             local bc2_v  = .
 99.             local bkc_v  = .
100.             local sek2_v = .
101.             local sec2_v = .
102.             local skc_v  = .
103. 
.             * Compute markup: mu = beta_cogs / alpha_hat where
.             * alpha = exp(cogs)/exp(go_corrected); go_corrected subtracts
.             * first-stage residual
.             gen mu = `bc_v' / (exp(cogs) / exp(go - epsilon))
104.             qui sum mu, d
105.             local mu_mean = r(mean)
106.         }
107.         else {
108. 
.             * Matches Python: np.linalg.lstsq(X, PHI) where X is the TL
.             * regressor matrix (const, k, cogs, k2, cogs2, kcogs).
.             qui reg phi k cogs k2 cogs2 kcogs
109.             matrix sv_tl = (_b[_cons], _b[k], _b[cogs], _b[k2], _b[cogs2],
>  _b[kcogs])
110.             sort id year
111.             mata: run_opt(&GMM_TL_OVERID(), st_matrix("sv_tl"), "bM", "cM"
> )
112.             local b0 = bM[1,1]
113.             replace phi = phi - `b0'
114.             replace Lphi = Lphi - `b0'
115.             matrix bMnc = bM[1,2..6]
116.             mata: compute_se("bMnc", ///
>                 ("k","Lcogs","k2","Lcogs2","kLcogs","Lk","L2cogs"), ///
>                 ("k","cogs","k2","cogs2","kcogs"), ///
>                 ("Lk","Lcogs","Lk2","Lcogs2","LkLcogs"))
117.             replace phi = phi + `b0'
118.             replace Lphi = Lphi + `b0'
119.             matrix seM = se_an
120. 
.             local bk_v   = bM[1,2]
121.             local bc_v   = bM[1,3]
122.             local bk2_v  = bM[1,4]
123.             local bc2_v  = bM[1,5]
124.             local bkc_v  = bM[1,6]
125.             local sek_v  = seM[1,1]
126.             local sec_v  = seM[1,2]
127.             local sek2_v = seM[1,3]
128.             local sec2_v = seM[1,4]
129.             local skc_v  = seM[1,5]
130. 
.             * Firm-year output elasticity of cogs: theta = bc + 2*bcc*c + bkc
> *k
.             gen theta_c = `bc_v' + 2*`bc2_v'*cogs + `bkc_v'*k
131.             gen mu = theta_c / (exp(cogs) / exp(go - epsilon))
132.             qui sum mu, d
133.             local mu_mean = r(mean)
134.         }
135. 
.         local crit_v = cM
136. 
.         * Append to results
.         preserve
137.         clear
138.         set obs 1
139.         gen sample = "`sample_label'"
140.         gen spec = "`spec_code'"
141.         gen N_obs = `nobs'
142.         gen b_k = `bk_v'
143.         gen se_k = `sek_v'
144.         gen b_cogs = `bc_v'
145.         gen se_cogs = `sec_v'
146.         gen b_k2 = `bk2_v'
147.         gen se_k2 = `sek2_v'
148.         gen b_cogs2 = `bc2_v'
149.         gen se_cogs2 = `sec2_v'
150.         gen b_kcogs = `bkc_v'
151.         gen se_kcogs = `skc_v'
152.         gen markup_mean = `mu_mean'
153.         gen criterion = `crit_v'
154.         append using `results'
155.         save `results', replace
156.         restore
157. 
.         dis "    beta_k = " %7.4f `bk_v' " (" %6.4f `sek_v' "), " ///
>             "beta_c = " %7.4f `bc_v' " (" %6.4f `sec_v' "), " ///
>             "mu_bar = " %6.3f `mu_mean'
158.     }
159. }


