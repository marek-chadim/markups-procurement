. *-----------------------------------------------------------------------
. * Build LaTeX table (Beer C2 layout: 2 panels x 4 columns)
. *-----------------------------------------------------------------------
. 
. cap file close tf

. * Write to the canonical paper-input path (4_paper/input/tables is a
. * symlink to 2_analysis/output/tables, so this file is directly visible
. * to the paper without a copy step).
. file open tf using "../../output/tables/table_pf_estimates.tex", write replac
> e

. 
. local samples `" "Pooled" "NACE 41" "NACE 42" "NACE 43" "'

. 
. #delimit ;
delimiter now ;
. file write tf
>     "\begin{table}[htbp]\centering" _n
>     "\caption{Production Function Parameter Estimates "
>     "(Beer 2024 Table C2 format)}\label{tab:pf_estimates}" _n
>     "\begin{threeparttable}" _n
>     "\begin{tabular}{l*{4}{c}}" _n
>     "\toprule" _n
>     " & Pooled & NACE 41 & NACE 42 & NACE 43 \\" _n
>     " & (year "  _char(36) "\times" _char(36) " nace2 FE) & (Buildings) "
>     "& (Civil Eng.) & (Specialized) \\" _n
>     "\midrule" _n
>     "\multicolumn{5}{l}{\textit{Panel A: Cobb-Douglas (survival "
>     "correction, pp in Markov)}} \\" _n
> ;

. #delimit cr
delimiter now cr
. 
. * Load results into memory once, then use in/if to filter rows.
. * Row order after the main loop: NACE 43 TL, NACE 43 CD, NACE 42 TL,
. * NACE 42 CD, NACE 41 TL, NACE 41 CD, Pooled TL, Pooled CD, init.
. * We dropped init already. For clean row addressing, we need to sort
. * deterministically so (sample, spec) lookup works.
. use "$data/beer_c2_estimates.dta", clear

. gen _sample_order = cond(sample == "Pooled", 1, ///
>     cond(sample == "NACE 41", 2, cond(sample == "NACE 42", 3, 4)))

. gen _spec_order = cond(spec == "cd", 1, 2)

. sort _sample_order _spec_order

. tempfile ordered

. save `ordered'
file /var/folders/4c/ww4k0h5j0fq1529s2dttb4t00000gn/T//St58559.00000a saved
    as .dta format

. 
. * Helper: rowwrite_coef loops over 4 samples for a given spec and
. * coefficient column.
. #delimit ;
delimiter now ;
. local cd_coefs b_k se_k b_cogs se_cogs;

. local tl_coefs b_k se_k b_cogs se_cogs b_k2 se_k2 b_cogs2 se_cogs2 b_kcogs se
> _kcogs;

. #delimit cr
delimiter now cr
. 
. * Panel A: CD coefficients. Rows: beta_k with (SE), beta_cogs with (SE)
. foreach co in k cogs {
  2.     if "`co'" == "k"    local lab "\$\hat{\beta}_k\$"
  3.     if "`co'" == "cogs" local lab "\$\hat{\beta}_{\text{cogs}}\$"
  4.     file write tf "`lab'"
  5.     foreach s in "Pooled" "NACE 41" "NACE 42" "NACE 43" {
  6.         use `ordered', clear
  7.         qui keep if sample == "`s'" & spec == "cd"
  8.         if _N == 0 {
  9.             file write tf " & --"
 10.         }
 11.         else {
 12.             local v = b_`co'[1]
 13.             if missing(`v') {
 14.                 file write tf " & --"
 15.             }
 16.             else {
 17.                 file write tf " & " %7.4f (`v')
 18.             }
 19.         }
 20.     }
 21.     file write tf " \\" _n
 22.     file write tf " "
 23.     foreach s in "Pooled" "NACE 41" "NACE 42" "NACE 43" {
 24.         use `ordered', clear
 25.         qui keep if sample == "`s'" & spec == "cd"
 26.         if _N == 0 {
 27.             file write tf " & "
 28.         }
 29.         else {
 30.             local v = se_`co'[1]
 31.             if missing(`v') {
 32.                 file write tf " & "
 33.             }
 34.             else {
 35.                 file write tf " & (" %6.4f (`v') ")"
 36.             }
 37.         }
 38.     }
 39.     file write tf " \\" _n
 40. }

. 
. * Panel A summary rows: RTS, mu_bar, N
. file write tf "RTS"

. foreach s in "Pooled" "NACE 41" "NACE 42" "NACE 43" {
  2.     use `ordered', clear
  3.     qui keep if sample == "`s'" & spec == "cd"
  4.     if _N == 0 {
  5.         file write tf " & --"
  6.     }
  7.     else {
  8.         local rts = b_k[1] + b_cogs[1]
  9.         file write tf " & " %6.3f (`rts')
 10.     }
 11. }

. file write tf " \\" _n

. 
. file write tf _char(36) "\bar{\mu}" _char(36)

. foreach s in "Pooled" "NACE 41" "NACE 42" "NACE 43" {
  2.     use `ordered', clear
  3.     qui keep if sample == "`s'" & spec == "cd"
